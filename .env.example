# Local provider
OLIVAW_LOCAL_BASE_URL=http://localhost:11434
OLIVAW_LOCAL_MODEL=llama3.1:8b

# Cloud provider: disabled by default.
# For persistent local use, prefer:
# ~/Library/Application Support/Olivaw/config.toml
OPENAI_API_KEY=
OLIVAW_CLOUD_ENABLED=false
OLIVAW_CLOUD_MODEL=gpt-4.1-mini
# disabled | manual-only | automatic
OLIVAW_CLOUD_FALLBACK=manual-only

# Optional Prime Observer source override
OLIVAW_PRIME_OBSERVER_DIR=~/prime-observer/viz
OLIVAW_PRIME_OBSERVER_ENABLED=true
# OLIVAW_PRIME_OBSERVER_BASE_URL=http://127.0.0.1:8000

# Optional Core Signal source override
OLIVAW_CORE_SIGNAL_DIR=~/core-signal/reports
OLIVAW_CORE_SIGNAL_ENABLED=true
